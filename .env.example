# daily-report skill 配置示例
#
# 复制为 .env（或用任何喜欢的方式把这些变量 export 到 skill 运行环境），
# 把占位值替换成自己的值。未标记 [optional] 的均为必填。
#
# 按重构阶段分组：阶段 A 已启用，阶段 B/C/D 在后续提交中逐步启用。
#
# ============================================================
# 阶段 A：身份与敏感信息（已启用）
# ============================================================

# GitHub 用户名（collect/github-events.sh、build-opposing-prompt.py）
GITHUB_USER=your-github-login

# 博客仓库（publish/verify-published.sh 用 gh api 校验文章已发布）
DAILY_REPORT_REPO=your-github-login/your-blog-repo

# 收件邮箱（publish/send-email.sh；阶段 C 后可通过 DR_MAIL_CMD 改接口）
DAILY_REPORT_EMAIL_TO=you@example.com

# send-email.sh 判定投递成功的 grep 标记；默认匹配自研 `mails` CLI 的 "Sent via mails.dev"
# 换邮件工具时改这个，无需改脚本本体。
# 含空格的值必须加引号（Python loader 支持；bash source 也需要）。
DR_MAIL_SUCCESS_GREP="Sent via mails.dev"

# cc-connect 运行时会自动注入 CC_PROJECT / CC_SESSION_KEY 指向当前会话。
# 如果想把"日报完成通知"发到固定的主 DM（而不是当前会话），设置下面 OVERRIDE：
# 格式示例：telegram:<user_id>:<chat_id>
CC_SESSION_KEY_OVERRIDE=
CC_PROJECT_OVERRIDE=

# 不用 cc-connect 的话，阶段 C 提供 DR_NOTIFY_CMD=: 可完全静默

# Codex 反方 Telegram 群 chat_id（publish/send-telegram-opposing.sh）
# 如果你不用 codex 反方推送，保持空值，脚本会静默跳过
CODEX_GROUP_ID=

# ============================================================
# 阶段 B：PERSONA 注入（待启用）
# ============================================================

# 作者 Agent 显示名（写入 signature、prompt 模板）
AUTHOR_AGENT_NAME=YourAgent
AUTHOR_NAME=Your Name
AUTHOR_URL=https://github.com/your-github-login

# 协作者 / 用户的代号，用于候选建议段"给用户（USER_NAME）"
USER_NAME=YourUser

# PERSONA 文件路径（覆盖 skill 内 PERSONA.example.md 的身份模板）
DAILY_REPORT_PERSONA=

# ============================================================
# 阶段 C：可插拔接口（待启用）
# ============================================================

# 通知命令；默认走 scripts/publish/send-cc-notification.sh
# 用 `:`（no-op）可静默关闭；也可换成 slack-cli / webhook 脚本
DR_NOTIFY_CMD=

# 邮件命令；默认走 scripts/publish/send-email.sh（依赖 mails CLI）
DR_MAIL_CMD=

# facets submodule 发布命令；默认走 scripts/publish/publish-artifacts.sh
DR_FACETS_PUBLISH_CMD=

# 异构反方评审 backend；默认 `codex-plugin`，由 run-opposing-agent.py 的
# `--opposing-backend` / `OPPOSING_BACKEND` 选择。接新 backend（如 kimi-code）
# 见 scripts/README.md 的「反方 reviewer backend」段。
# OPPOSING_BACKEND=codex-plugin

# ============================================================
# 路径与基础设施
# ============================================================

# 博客仓库本地 checkout 根目录（必填）
BLOG_DIR=/path/to/blog

# facets 归档根目录（可选，未设时推导为 $BLOG_DIR/facets/facets）
BLOG_FACETS_ROOT=

# 外部容器留言目录（可选，跟 reference/workflows/01b-outside-notes.md 对齐）
OUTSIDE_NOTES_DIR=/path/to/notes/outside

# Claude Code projects 根目录，用于 session jsonl 发现（可选，默认 ~/.claude/projects）
CLAUDE_PROJECTS_ROOT=~/.claude/projects

# memory 目录（必填；新 memory 候选会写到这里并更新其中的 MEMORY.md）
MEMORY_DIR=/path/to/memory

# 时区（可选，默认 Asia/Shanghai）
DAILY_REPORT_TZ=Asia/Shanghai

# 反方 backend 子进程 cwd（可选，run-opposing-agent.py 传给 codex-plugin task；
# 默认 os.getcwd()，通常是你启动 Claude Code 的 workspace 根目录）
CODEX_CWD=

# 算法通过 cwd 路径段推导 repo 名的那一段名字（可选，默认 workspace）
# 适用于 /workspace/<repo>/... 这种容器布局；其他布局需覆盖
DR_WORKSPACE_SEGMENT=
